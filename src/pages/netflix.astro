---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import netflixData from '../data/netflix.json';

// FAQ Schema for AI Overview & featured snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "ポイント却下通知が来た場合の対処方法は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iOS設定を確認してください。既に却下されている場合は、サポートに申し立て可能です。"
      }
    },
    {
      "@type": "Question",
      "name": "ドコモ爆アゲセレクションの対象外と言われた時は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "dアカウントが既出の可能性があります。家族名義や別回線での申込をご検討ください。"
      }
    },
    {
      "@type": "Question",
      "name": "ポイント還元のタイミングはいつですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "えんためねっと報酬は30～60日後。ドコモポイントは翌月上旬から毎月付与開始します。"
      }
    }
  ]
};

// HowTo Schema for featured snippets
const howtoSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Netflix実質マイナス857円で契約する方法",
  "description": "えんためねっととドコモ爆アゲセレクションを組み合わせてNetflixを実質マイナス857円で契約する3ステップ",
  "step": [
    {
      "@type": "HowToStep",
      "position": "1",
      "name": "えんためねっと経由で申込",
      "text": "えんためねっと経由でドコモNetflix案件を申込して465円を確保します"
    },
    {
      "@type": "HowToStep",
      "position": "2",
      "name": "爆アゲセレクション適用",
      "text": "ドコモ『爆アゲセレクション』を適用し広告つきスタンダードを契約します"
    },
    {
      "@type": "HowToStep",
      "position": "3",
      "name": "ポイント大還元祭適用",
      "text": "『春のポイント大還元祭』で月額890円相当を3ヶ月間還元させます"
    }
  ],
  "totalTime": "PT15M",
  "estimatedCost": {
    "@type": "PriceSpecification",
    "priceCurrency": "JPY",
    "price": "0"
  }
};
---

<Layout
  title="Netflix実質マイナス857円で観る | アフィトク！"
  description="WBC全試合独占配信。地上波放送なし。だから、アフィトク！なら実質マイナス857円でNetflixを観られます。えんためねっと＋ドコモ爆アゲセレクションの最強ルート。"
  schemas={[faqSchema, howtoSchema]}
>
  <div class="min-h-screen bg-white pb-24">
    <Header showAlert={true} />

    <!-- Hero Section: The Answer -->
    <section class="px-4 py-8 bg-gradient-to-b from-[#E60012] to-[#b80a2f] text-white">
      <p class="text-xs font-bold text-gray-100 mb-2">WBC 地上波放送なし</p>
      <h1 class="text-lg font-black leading-tight mb-4">
        侍ジャパンを<br />タダ同然で観る。
      </h1>

      <!-- Big Number -->
      <div class="bg-white bg-opacity-20 backdrop-blur rounded-lg p-4 mb-4">
        <p class="text-xs text-gray-100 mb-1">実質価格（Netflixを契約した場合）</p>
        <div class="flex items-baseline gap-2">
          <p class="text-5xl font-black">-857</p>
          <p class="text-lg font-bold">円</p>
        </div>
        <p class="text-xs text-gray-100 mt-2">お釣りが出ます</p>
      </div>

      <!-- Breakdown -->
      <div class="bg-white bg-opacity-10 rounded-lg p-3 text-xs">
        <p class="text-gray-100 mb-2">計算内訳</p>
        <div class="space-y-1 text-gray-100">
          <p><span aria-hidden="true">📺</span> Netflix公式：<span class="font-bold">498円</span>（WBC応援キャンペーン）</p>
          <p><span aria-hidden="true">🎁</span> えんためねっと：<span class="font-bold">-465円</span>（報酬）</p>
          <p><span aria-hidden="true">📱</span> ドコモ還元：<span class="font-bold">-890円</span>（爆アゲ+大還元祭）</p>
          <p class="border-t border-gray-300 pt-1 mt-1 font-bold">
            = <span class="text-2xl">-857円</span>
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Button (Sticky) -->
    <div class="fixed bottom-0 left-0 right-0 max-w-md mx-auto px-4 py-3 bg-white border-t border-gray-200 z-40" style="padding-bottom: max(1rem, env(safe-area-inset-bottom));">
      <a href="https://www.yentame.net/index.asp?id=1225198" target="_blank" rel="noopener noreferrer" class="block w-full bg-[#E60012] hover:bg-[#b80a2f] text-white font-black py-4 rounded-lg text-center active:opacity-80 transition-opacity">
        えんためねっとで465円を確保する →
      </a>
    </div>

    <!-- Content Area -->
    <div class="pb-4">
      <!-- Step by Step Guide -->
      <section class="px-4 py-6 border-b border-gray-200" itemscope itemtype="https://schema.org/HowTo">
        <h2 class="text-sm font-black text-gray-900 mb-4">3ステップガイド</h2>
        <div class="space-y-3">
          {netflixData.best_route.steps.map((step, index) => (
            <div class="flex gap-3" itemprop="step" itemscope itemtype="https://schema.org/HowToStep">
              <div class="flex-shrink-0 w-8 h-8 bg-[#E60012] text-white rounded-full flex items-center justify-center font-black text-xs">
                <meta itemprop="position" content={String(index + 1)} />
                {index + 1}
              </div>
              <div class="flex-1 pt-1">
                <p class="text-sm text-gray-900 leading-relaxed" itemprop="text">{step}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Warning Box -->
        <div class="mt-4 bg-yellow-50 border-l-4 border-yellow-400 p-3 rounded text-xs">
          <p class="font-bold text-yellow-800 mb-2">⚠️ 重要な注意</p>
          <ul class="text-yellow-700 space-y-1">
            <li>• iOSユーザー：Safari設定で「サイト越えトラッキング」をオフに</li>
            <li>• 申込中はブラウザを閉じないこと</li>
            <li>• ポイント確定：30～60日後</li>
          </ul>
        </div>
      </section>

      <!-- Ranking Table -->
      <section class="px-4 py-6 border-b border-gray-200">
        <h2 class="text-sm font-black text-gray-900 mb-4">ポイントサイト報酬TOP5</h2>
        <div class="space-y-2">
          {netflixData.rewards.map((reward, index) => {
            const medals = ['🥇', '🥈', '🥉'];
            const medal = medals[index] || '';
            return (
              <a href={reward.link} target="_blank" rel="noopener noreferrer" class="block bg-white border border-gray-300 rounded-lg p-3 active:bg-gray-50 transition-colors">
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 flex-1">
                    {medal && <span class="text-lg">{medal}</span>}
                    <div>
                      <p class="text-sm font-bold text-gray-900">{reward.site}</p>
                      <p class="text-xs text-gray-600">判定期間：30～90日</p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-lg font-black text-[#E60012]">{reward.amount}円</p>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- Technical Advisory -->
      <section class="px-4 py-6 border-b border-gray-200">
        <h2 class="text-sm font-black text-gray-900 mb-4">失敗しないための技術ガイド</h2>

        <div class="space-y-4">
          <!-- iOS Setting -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
            <p class="text-xs font-bold text-blue-900 mb-2"><span aria-hidden="true">📱</span> iOSユーザー（必須）</p>
            <ol class="text-xs text-blue-800 space-y-1 ml-3 list-decimal">
              <li>Safari → 設定 → プライバシー</li>
              <li>「サイト越えトラッキングを防ぐ」を<span class="font-bold">OFF</span></li>
              <li>申込完了まで変更しない</li>
            </ol>
          </div>

          <!-- Cookie Management -->
          <div class="bg-green-50 border border-green-200 rounded-lg p-3">
            <p class="text-xs font-bold text-green-900 mb-2"><span aria-hidden="true">🍪</span> Cookie管理</p>
            <p class="text-xs text-green-800 mb-2">絶対NG：</p>
            <ul class="text-xs text-green-800 space-y-1 ml-3 list-disc">
              <li>シークレットモード</li>
              <li>Cookie削除</li>
              <li>VPN・プロキシ</li>
            </ul>
          </div>

          <!-- Judgment Period -->
          <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
            <p class="text-xs font-bold text-purple-900 mb-2"><span aria-hidden="true">⏱️</span> 判定期間</p>
            <div class="text-xs text-purple-800 space-y-1">
              <p>えんためねっと：30～60日</p>
              <p>げん玉：45日程度</p>
              <p>その他：60～90日</p>
              <p class="font-bold mt-2">期間中の解約は厳禁</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Troubleshooting -->
      <section class="px-4 py-6 border-b border-gray-200">
        <h2 class="text-sm font-black text-gray-900 mb-4">Q&A</h2>

        <div class="space-y-3 text-xs">
          <div>
            <p class="font-bold text-[#E60012] mb-1"><span aria-hidden="true">Q:</span> ポイント却下通知が来た</p>
            <p class="text-gray-700"><span aria-hidden="true">A:</span> iOS設定を確認してください。既に却下されている場合は、サポートに申し立て可能です。</p>
          </div>

          <div>
            <p class="font-bold text-[#E60012] mb-1"><span aria-hidden="true">Q:</span> ドコモ爆アゲ対象外と言われた</p>
            <p class="text-gray-700"><span aria-hidden="true">A:</span> dアカウントが既出の可能性。家族名義や別回線での申込を検討してください。</p>
          </div>

          <div>
            <p class="font-bold text-[#E60012] mb-1"><span aria-hidden="true">Q:</span> 還元タイミングは？</p>
            <p class="text-gray-700"><span aria-hidden="true">A:</span> えんためねっと報酬は30～60日後。ドコモポイントは翌月上旬から毎月付与開始。</p>
          </div>
        </div>
      </section>

      <!-- Info Footer -->
      <section class="px-4 py-6 text-xs text-gray-600">
        <p class="mb-2">最終更新：{new Date(netflixData.last_updated).toLocaleDateString('ja-JP')}</p>
        <p>本情報は参考です。最新情報は各公式サイトでご確認ください。</p>
      </section>
    </div>
  </div>

</Layout>

<style>
  a {
    text-decoration: none;
    color: inherit;
  }
</style>
