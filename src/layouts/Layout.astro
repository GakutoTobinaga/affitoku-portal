---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'アフィトク！| 自己アフィリエイト・ポイ活報酬計算エンジン', description = 'あなたの「実質利益」が今すぐわかる。アフィトク！は、自己アフィリエイトとポイ活の実質価格を算出する最終回答エンジンです。' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#002A5B" />

    <!-- OGP Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://affitoku.jp" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts (Noto Sans JP) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

    <!-- Canonical -->
    <link rel="canonical" href="https://affitoku.jp" />

    <!-- JSON-LD (Organization Schema) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "アフィトク！",
        "url": "https://affitoku.jp",
        "description": "自己アフィリエイト・ポイ活の実質価格計算エンジン"
      }
    </script>

    <title>{title}</title>
    <style>
      :root {
        --affitoku-red: #E60012;
        --affitoku-navy: #002A5B;
        --affitoku-gray: #F8F8F8;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: 'Noto Sans JP', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      body {
        background-color: #FFFFFF;
        color: #1a1a1a;
        overflow-x: hidden;
      }

      /* Safe Area Support for notch devices */
      @supports (padding: max(0px)) {
        body {
          padding-bottom: max(0px, env(safe-area-inset-bottom));
        }
      }
    </style>
  </head>
  <body>
    <main class="max-w-md mx-auto min-h-screen bg-white">
      <slot />
    </main>
  </body>
</html>
