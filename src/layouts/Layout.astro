---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'アフィトク！| 自己アフィリエイト・ポイ活報酬計算エンジン', description = 'あなたの「実質利益」が今すぐわかる。アフィトク！は、自己アフィリエイトとポイ活の実質価格を算出する最終回答エンジンです。' } = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#002A5B" />

    <!-- OGP Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://affitoku.jp" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts (Noto Sans JP) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

    <!-- Canonical -->
    <link rel="canonical" href="https://affitoku.jp" />

    <!-- Google Analytics 4 via Partytown (Off-main-thread) -->
    <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script type="text/partytown" is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>

    <!-- JSON-LD (Organization Schema) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "アフィトク！",
        "url": "https://affitoku.jp",
        "description": "自己アフィリエイト・ポイ活の実質価格計算エンジン"
      }
    </script>

    <!-- Product Schema with AggregateOffer (Google Search Console Validation) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": "WBC2026独占配信：Netflix実質最安視聴プラン",
        "image": "https://affitoku.jp/og-image.jpg",
        "description": "地上波放送なしのWBCを実質マイナス857円で視聴する方法。公式価格498円に対し、えんためねっと報酬（465円）とドコモ爆アゲセレクション（890円還元）を組み合わせた最大利益スキームを解説。複数ポイントサイトの報酬キャンペーン活用で実現する逆転現象。",
        "brand": {
          "@type": "Brand",
          "name": "アフィトク！"
        },
        "aggregateOffer": {
          "@type": "AggregateOffer",
          "offerCount": 6,
          "lowPrice": "33",
          "highPrice": "498",
          "priceCurrency": "JPY",
          "priceValidUntil": "2026-12-31T23:59:59+09:00",
          "availability": "https://schema.org/InStock",
          "url": "https://affitoku.jp/netflix/",
          "offers": [
            {
              "@type": "Offer",
              "name": "えんためねっと",
              "description": "報酬465円 + ドコモ還元で実質マイナス857円達成可能",
              "price": "33",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://www.yentame.net/index.asp?id=1225198"
            },
            {
              "@type": "Offer",
              "name": "げん玉",
              "description": "ポイントサイト報酬400円",
              "price": "98",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://www.gendama.jp/"
            },
            {
              "@type": "Offer",
              "name": "トリマ",
              "description": "ポイントサイト報酬375円",
              "price": "123",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://web.trip-mile.com/"
            },
            {
              "@type": "Offer",
              "name": "アメフリ",
              "description": "ポイントサイト報酬350円",
              "price": "148",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://www.amefri.net/"
            },
            {
              "@type": "Offer",
              "name": "ハピタス",
              "description": "ポイントサイト報酬250円",
              "price": "248",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://hapitas.jp/"
            },
            {
              "@type": "Offer",
              "name": "公式直接契約",
              "description": "キャンペーン適用なし",
              "price": "498",
              "priceCurrency": "JPY",
              "availability": "https://schema.org/InStock",
              "url": "https://affitoku.jp/netflix/"
            }
          ]
        }
      }
    </script>

    <title>{title}</title>
    <style>
      :root {
        --affitoku-red: #E60012;
        --affitoku-navy: #002A5B;
        --affitoku-gray: #F8F8F8;
        color-scheme: light dark;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: 'Noto Sans JP', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        -webkit-tap-highlight-color: transparent;
      }

      body {
        background-color: #FFFFFF;
        color: #1a1a1a;
        overflow-x: hidden;
        /* Safe Area Support for notch devices */
        padding-top: max(0px, env(safe-area-inset-top));
        padding-bottom: max(0px, env(safe-area-inset-bottom));
      }

      /* Performance: Prevent layout shifts */
      img {
        display: block;
      }

      /* Smooth scroll behavior */
      html {
        scroll-behavior: smooth;
      }

      /* Safe Area inset variables for Tailwind */
      @supports (padding: max(0px)) {
        :root {
          --safe-area-inset-top: max(0px, env(safe-area-inset-top));
          --safe-area-inset-right: max(0px, env(safe-area-inset-right));
          --safe-area-inset-bottom: max(0px, env(safe-area-inset-bottom));
          --safe-area-inset-left: max(0px, env(safe-area-inset-left));
        }
      }

      /* Prevent CLS (Cumulative Layout Shift) */
      html {
        scroll-padding-top: env(safe-area-inset-top);
      }
    </style>
  </head>
  <body>
    <main class="max-w-md mx-auto min-h-screen bg-white">
      <slot />
    </main>
  </body>
</html>
