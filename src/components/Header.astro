---
interface Props {
  showAlert?: boolean;
}

const { showAlert = false } = Astro.props;
---

<header class="sticky top-0 z-50 bg-[#002A5B] text-white shadow-lg" style="padding-top: max(0px, env(safe-area-inset-top));">
  <div class="px-4 py-3 flex items-center justify-between">
    <!-- Logo（赤のみ・白背景なし） - Home Link for SEO -->
    <a href="/" class="flex items-center gap-2 flex-shrink-0" title="アフィトク！ - ホームへ">
      <img src="/logo.svg" alt="アフィトク！" class="h-10 w-auto" width="180" height="40" loading="eager" decoding="async" />
    </a>

    <!-- Alert Badge -->
    {showAlert && (
      <div class="animate-pulse">
        <span class="inline-block bg-[#E60012] text-white text-xs font-bold px-2 py-1 rounded">
          WBC 緊急
        </span>
      </div>
    )}
  </div>

  <!-- Subheader -->
  <div class="px-4 pb-2 text-xs text-gray-300">
    実質価格の最終回答エンジン
  </div>
</header>

